<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <PackageVersion>10.0.0</PackageVersion>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="BlazorLocalization.Extensions.Tests" />
    </ItemGroup>

    <PropertyGroup Label="Package Properties">
        <Title>BlazorLocalization.Extensions</Title>
        <Description>Cache-backed IStringLocalizer with FusionCache, SmartFormat.NET template support, and pluggable translation providers for Blazor applications.</Description>
        <PackageId>BlazorLocalization.Extensions</PackageId>
        <PackageTags>blazor;localization;i18n;internationalization;IStringLocalizer;fusioncache;smartformat;translation;asp.net-core</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <None Include="../../README.md" Pack="true" PackagePath=""/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="10.0.3"/>
        <PackageReference Include="Microsoft.Extensions.Localization.Abstractions" Version="10.0.3"/>
        <PackageReference Include="Microsoft.Extensions.Logging.Configuration" Version="10.0.3"/>
        <PackageReference Include="SmartFormat.NET" Version="3.*"/>
        <PackageReference Include="ZiggyCreatures.FusionCache" Version="2.*"/>
        <PackageReference Include="ZiggyCreatures.FusionCache.Serialization.SystemTextJson" Version="2.5.0"/>
    </ItemGroup>

</Project>
